<?xml version="1.0" encoding="UTF-8"?>
<apacheConfiguration>
  <description>Apache Security Headers Configuration</description>
  
  <!-- Disable directory listing -->
  <filesMatch pattern="^$">
    <order>allow,deny</order>
    <deny>from all</deny>
  </filesMatch>
  
  <!-- Hide server software and technology information -->
  <headers>
    <unset name="X-Powered-By"/>
    <unset name="X-AspNet-Version"/>
    <unset name="X-AspNetMvc-Version"/>
    <unset name="Server"/>
    <set name="Server" value="Apache" always="true"/>
  </headers>
  
  <!-- Content Security Policy -->
  <header name="Content-Security-Policy" 
    value="default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://formspree.io; frame-ancestors 'self'; form-action 'self' https://formspree.io; base-uri 'self'; object-src 'none'; media-src 'none'; frame-src 'none';" 
    always="true"/>
  
  <!-- X-Content-Type-Options -->
  <header name="X-Content-Type-Options" value="nosniff" always="true"/>
  
  <!-- X-Frame-Options -->
  <header name="X-Frame-Options" value="SAMEORIGIN" always="true"/>
  
  <!-- Referrer-Policy -->
  <header name="Referrer-Policy" value="strict-origin-when-cross-origin" always="true"/>
  
  <!-- X-XSS-Protection -->
  <header name="X-XSS-Protection" value="1; mode=block" always="true"/>
  
  <!-- Permissions-Policy -->
  <header name="Permissions-Policy" value="camera=(), microphone=(), geolocation=(), payment=()" always="true"/>
  
  <!-- Expect-CT -->
  <header name="Expect-CT" value="max-age=86400, enforce" always="true"/>
  
  <!-- HSTS (uncomment when HTTPS is configured) -->
  <!-- <header name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains; preload" always="true"/> -->
  
  <!-- Disable ETags -->
  <headers>
    <unset name="ETag"/>
  </headers>
  <fileETag>None</fileETag>
  
  <!-- Prevent access to sensitive files -->
  <filesMatch pattern="\.(env|json|lock|yml|yaml|git|htaccess|bak|backup|sql|db)$">
    <order>allow,deny</order>
    <deny>from all</deny>
  </filesMatch>
  
  <!-- Set charset for HTML files -->
  <addDefaultCharset>utf-8</addDefaultCharset>
  <filesMatch pattern="\.html?$">
    <header name="Content-Type" value="text/html; charset=utf-8" set="true"/>
  </filesMatch>
  
  <!-- Enable compression -->
  <ifModule name="mod_deflate">
    <addOutputFilterByType>
      <type>text/html</type>
      <type>text/plain</type>
      <type>text/xml</type>
      <type>text/css</type>
      <type>text/javascript</type>
      <type>application/javascript</type>
      <filter>DEFLATE</filter>
    </addOutputFilterByType>
  </ifModule>
  
  <!-- Cache control for static assets -->
  <filesMatch pattern="\.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|eot)$">
    <header name="Cache-Control" value="public, max-age=31536000, immutable" set="true"/>
  </filesMatch>
  
  <!-- Cache control for HTML -->
  <filesMatch pattern="\.html?$">
    <header name="Cache-Control" value="public, max-age=3600, must-revalidate" set="true"/>
  </filesMatch>
  
  <!-- Disable script execution in upload directories -->
  <directory path="/var/www/html/uploads">
    <phpFlag name="engine" value="off"/>
    <addType>
      <extension>php</extension>
      <extension>php3</extension>
      <extension>php4</extension>
      <extension>php5</extension>
      <extension>phtml</extension>
      <mimeType>text/plain</mimeType>
    </addType>
  </directory>
</apacheConfiguration>
